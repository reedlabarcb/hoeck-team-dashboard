#!/usr/bin/env sh
# Hoeck Team Dashboard — pre-commit hook
# Blocks destructive RealNex/Box/DB method names from being added outside lib/external/*
# Reference: BUILD_SPEC.md "Enforcement" section.

set -e

FORBIDDEN="deleteFile|deleteFolder|moveFile|moveFolder|renameFile|updateCompany|updateContact|deleteCompany|deleteContact|updateActivity|deleteActivity|hardDelete|writeMasterExcel|updateMasterExcel|deleteMasterExcel|modifyMasterExcel|overwriteMasterExcel|replaceMasterExcel|setMasterExcelCell|saveMasterExcel|editCompany|editContact|putCompany|putContact|patchCompany|patchContact|updateHistory|putHistory|patchHistory|deleteHistory|updateGroup|putGroup|patchGroup|deleteGroup|realnexPut|realnexPatch|realnexDelete|realnexRequest"

# Look at staged Added/Copied/Modified files outside lib/external/ and test files.
# Fail if any contain the forbidden patterns.
VIOLATIONS=$(
  git diff --cached --name-only --diff-filter=ACM \
    | grep -v "^lib/external/" \
    | grep -v "\.test\." \
    | grep -v "^docs/" \
    | grep -v "^BUILD_SPEC\.md$" \
    | grep -v "^AGENTS\.md$" \
    | grep -v "^MEMORY\.md$" \
    | grep -v "^\.husky/" \
    | xargs -r grep -l -E "$FORBIDDEN" 2>/dev/null || true
)

if [ -n "$VIOLATIONS" ]; then
  echo ""
  echo "ERROR: Forbidden destructive methods found outside lib/external/:"
  echo "$VIOLATIONS"
  echo ""
  echo "Allowed pattern: methods like updateCompany / deleteFile / moveFolder may only"
  echo "exist inside lib/external/ (and even there only as explicitly-forbidden tests)."
  echo "If you have a legitimate reason, name the method differently or move it."
  exit 1
fi

# ----------------------------------------------------------------------------
# Block `new Pool(` outside lib/db/ and scripts/.
# Reason: Phase 2 connection-pool leak — see docs/LESSONS_LEARNED.md.
# Route handlers and library modules must use the shared singleton from lib/db/index.ts.
# Only CLI scripts (which exit after running) may create their own Pool.
# Test files are also exempt (they may need their own fixtures).
# ----------------------------------------------------------------------------
POOL_VIOLATIONS=$(
  git diff --cached --name-only --diff-filter=ACM \
    | grep -E "\.(ts|tsx|js|mjs)$" \
    | grep -v "^lib/db/" \
    | grep -v "^scripts/" \
    | grep -v "\.test\." \
    | xargs -r grep -l -E "new[[:space:]]+Pool[[:space:]]*\(" 2>/dev/null || true
)

if [ -n "$POOL_VIOLATIONS" ]; then
  echo ""
  echo "ERROR: 'new Pool(' found outside lib/db/ and scripts/:"
  echo "$POOL_VIOLATIONS"
  echo ""
  echo "Route handlers and library modules must NEVER instantiate their own Postgres Pool."
  echo "Import the shared singleton: import { db } from '@/lib/db'"
  echo "See docs/LESSONS_LEARNED.md \"Phase 2 — Postgres connection pool leak\" for context."
  echo "If you have a legitimate reason (e.g. a new CLI script), put it under scripts/."
  exit 1
fi

# ----------------------------------------------------------------------------
# RealNex base URL may ONLY appear inside lib/external/realnex/ (the wrapper +
# its HTTP client). All RealNex traffic goes through the wrapper, whose client
# exposes no PUT/PATCH/DELETE primitive. A raw `sync.realnex.com` reference
# anywhere else means someone is bypassing the wrapper (and could issue a
# mutating verb) — block it. Reference: docs/PHASE3_BUILD_PLAN.md "Write Safety".
# ----------------------------------------------------------------------------
REALNEX_RAW_VIOLATIONS=$(
  git diff --cached --name-only --diff-filter=ACM \
    | grep -E "\.(ts|tsx|js|mjs)$" \
    | grep -v "^lib/external/realnex/" \
    | grep -v "\.test\." \
    | xargs -r grep -l -E "sync\.realnex\.com" 2>/dev/null || true
)

if [ -n "$REALNEX_RAW_VIOLATIONS" ]; then
  echo ""
  echo "ERROR: raw 'sync.realnex.com' reference outside lib/external/realnex/:"
  echo "$REALNEX_RAW_VIOLATIONS"
  echo ""
  echo "All RealNex calls MUST go through lib/external/realnex/safe.ts (read+create only)."
  echo "A raw RealNex URL elsewhere bypasses the create-only safety wrapper."
  exit 1
fi

# Run safe-wrapper forbidden-method assertions before allowing the commit.
# These tests fail if anyone exports a forbidden method from lib/external/*/safe.ts.
if [ -f "node_modules/.bin/vitest" ]; then
  npx vitest run lib/external --reporter=dot 2>&1 || {
    echo ""
    echo "ERROR: Safe-wrapper tests failed. Commit blocked."
    exit 1
  }
fi

exit 0
